rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isTeacher() {
      return signedIn() && request.auth.token.email == 't2bin@uryeo-h.gne.go.kr';
    }
    function isRoomMember(roomId) {
      return signedIn() && exists(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }
    function isRoomMemberAfter(roomId) {
      return signedIn() && existsAfter(/databases/$(database)/documents/rooms/$(roomId)/players/$(request.auth.uid));
    }
    match /rooms/{roomId} {
      allow create: if isTeacher() && request.resource.data.teacherId == request.auth.uid;
      allow get: if signedIn();
      allow list: if false;
      // 게임 중에는 방 멤버(스틸 도전·아이템 사용·재입장 포함)가 snapshot을 갱신할 수 있다.
      // status 전환(lobby→playing 등)은 교사만 가능.
      allow update: if request.resource.data.teacherId == resource.data.teacherId
        && request.resource.data.code == resource.data.code
        && (isTeacher()
          || ((isRoomMember(roomId) || isRoomMemberAfter(roomId))
            && request.resource.data.status == resource.data.status
            && (resource.data.status == 'lobby' || resource.data.status == 'playing')));
      allow delete: if isTeacher() && resource.data.teacherId == request.auth.uid;

      match /players/{playerId} {
        allow create: if signedIn() && playerId == request.auth.uid;
        allow read: if isTeacher() || isRoomMember(roomId);
        allow update: if isTeacher() || (signedIn() && playerId == request.auth.uid);
        allow delete: if isTeacher();
      }

      match /claims/{tileId} {
        allow read: if isTeacher() || isRoomMember(roomId);
        allow write: if isTeacher();
      }
    }

    match /roomCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow write: if isTeacher();
    }

    match /quizPublic/{questionId} {
      allow read: if signedIn();
      allow write: if isTeacher();
    }

    // Answers are never readable by students. Rules may compare against them.
    match /quizAnswers/{questionId} {
      allow read: if isTeacher();
      allow write: if isTeacher();
    }

    match /metadata/{documentId} {
      allow read: if signedIn();
      allow write: if isTeacher();
    }

    match /rooms/{roomId}/attempts/{attemptId} {
      allow create: if (isTeacher() || isRoomMember(roomId))
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.selectedAnswer is int
        && request.resource.data.selectedAnswer >= 1
        && request.resource.data.selectedAnswer <= 5;
      allow read: if isTeacher() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    match /rooms/{roomId}/correct/{attemptId} {
      allow create: if (isTeacher() || isRoomMember(roomId))
        && request.resource.data.userId == request.auth.uid
        && exists(/databases/$(database)/documents/rooms/$(roomId)/attempts/$(attemptId))
        && get(/databases/$(database)/documents/rooms/$(roomId)/attempts/$(attemptId)).data.userId == request.auth.uid
        && request.resource.data.questionId == get(/databases/$(database)/documents/rooms/$(roomId)/attempts/$(attemptId)).data.questionId
        && get(/databases/$(database)/documents/quizAnswers/$(request.resource.data.questionId)).data.answer == get(/databases/$(database)/documents/rooms/$(roomId)/attempts/$(attemptId)).data.selectedAnswer;
      allow read: if isTeacher() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
